# =============================================================================
# Aurora LMS — Environment Variables
# Copy to .env.local and fill in. NEVER commit real secrets.
# All vars are validated at boot via src/env.ts (Zod). Missing required vars fail fast.
# =============================================================================

# --- Core ---
NODE_ENV=development
APP_URL=http://localhost:3000
APP_NAME="Aurora LMS"

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aurora?schema=public
# Optional separate pooled URL for serverless/edge
DATABASE_DIRECT_URL=postgresql://postgres:postgres@localhost:5432/aurora?schema=public

# --- Redis (cache, rate limiting, BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Auth (Auth.js / Better Auth) ---
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# Enterprise SSO (per-tenant config usually lives in DB; these are platform defaults)
SAML_SP_ENTITY_ID=
SAML_SP_CERT=
LDAP_URL=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=

# --- Object storage (S3-compatible: AWS S3, R2, MinIO) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=aurora-uploads
S3_FORCE_PATH_STYLE=true

# --- AI providers (abstraction layer picks based on availability) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
# Default models (override per-feature in config)
AI_DEFAULT_CHAT_MODEL=claude-sonnet-4-6
AI_DEFAULT_EMBEDDING_MODEL=text-embedding-3-large

# --- Email / notifications ---
EMAIL_FROM="Aurora LMS <no-reply@example.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# or a provider key (Resend/Postmark/SES)
EMAIL_PROVIDER_API_KEY=

# --- Observability ---
LOG_LEVEL=info
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Feature flags ---
# Default flag source; can be overridden by DB-backed flags per tenant
FEATURE_FLAGS_DEFAULT_ON=

# --- Security ---
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
ENCRYPTION_KEY=replace-with-openssl-rand-hex-32
